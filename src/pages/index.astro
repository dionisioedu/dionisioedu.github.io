---
const options = [
  {
    locale: 'pt',
    title: 'Português',
    description:
      'Portfólio, blog, loja e referência técnica para acompanhar o trabalho de @dionisiodev em software, IA aplicada e produto.',
    href: '/pt/',
    cta: 'Entrar em português',
    image: '/assets/images/projects-2.webp',
  },
  {
    locale: 'en',
    title: 'English',
    description:
      'Portfolio, writing, products, and technical reference for people following @dionisiodev across software, applied AI, and product work.',
    href: '/en/',
    cta: 'Enter in English',
    image: '/assets/images/desktop-5.webp',
  },
];

const pillars = [
  {
    title: 'Portfolio',
    body: 'Real projects with product thinking, architecture, UX, and delivery decisions in context.',
  },
  {
    title: 'Blog',
    body: 'Writing on software engineering, applied AI, career growth, and practical technical judgment.',
  },
  {
    title: 'Store',
    body: 'eBooks, materials, and curated recommendations that support real developer routines.',
  },
  {
    title: 'Reference',
    body: 'Guides, labs, and fundamentals for studying better and returning faster to execution.',
  },
];

const socials = [
  { label: 'X', href: 'https://x.com/dionisiodev' },
  { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev' },
  { label: 'Medium', href: 'https://medium.com/@dionisiodev' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dionisio Developer</title>
    <meta
      name="description"
      content="Dionisio Developer is the home base for @dionisiodev: portfolio, blog, store, and technical reference across software engineering, applied AI, and product work."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0d1418;
        --surface: rgba(13, 23, 29, 0.96);
        --surface-soft: rgba(210, 233, 236, 0.05);
        --border: rgba(210, 233, 236, 0.12);
        --border-strong: rgba(210, 233, 236, 0.22);
        --text: #f3f8fa;
        --muted: #afc3cb;
        --accent: #38c6ca;
        --shadow: 0 24px 64px rgba(0, 0, 0, 0.28);
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: Inter, "Segoe UI", system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(56, 198, 202, 0.12), transparent 30%),
          linear-gradient(180deg, #121a20 0%, var(--bg) 100%);
      }

      main {
        width: min(1160px, calc(100% - 32px));
        margin: 0 auto;
        padding: 40px 0 64px;
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.9fr);
        gap: 20px;
        padding: 26px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .eyebrow {
        margin: 0 0 12px;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        line-height: 1.05;
      }

      h1 {
        max-width: 10ch;
        font-size: clamp(2.8rem, 6vw, 5.6rem);
      }

      .lede {
        margin: 18px 0 0;
        max-width: 60ch;
        color: var(--muted);
        font-size: 1.05rem;
        line-height: 1.75;
      }

      .actions,
      .socials {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .actions {
        margin-top: 22px;
      }

      .action,
      .socials a,
      .card a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 8px;
        border: 1px solid transparent;
        font-weight: 700;
        text-decoration: none;
        transition: transform 160ms ease, background 160ms ease, color 160ms ease, border-color 160ms ease;
      }

      .action,
      .card a {
        background: var(--accent);
        color: #081115;
        -webkit-text-fill-color: #081115;
      }

      .action.secondary {
        background: transparent;
        border: 1px solid var(--border-strong);
        color: var(--text);
        -webkit-text-fill-color: var(--text);
      }

      .socials a {
        background: transparent;
        border-color: var(--border-strong);
        color: var(--text);
        -webkit-text-fill-color: var(--text);
      }

      .action:hover,
      .socials a:hover,
      .card a:hover {
        transform: translateY(-1px);
      }

      .action.secondary:hover,
      .socials a:hover {
        background: var(--surface-soft);
      }

      .side-panel,
      .card,
      .pillars article {
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface-soft);
      }

      .side-panel {
        padding: 18px;
        display: grid;
        gap: 16px;
        align-content: start;
      }

      .side-panel p,
      .side-panel li,
      .footer-note {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .side-panel ul {
        margin: 0;
        padding-left: 1rem;
      }

      .side-panel li + li {
        margin-top: 0.5rem;
      }

      .side-panel a,
      .footer-note a {
        color: var(--text);
      }

      .pillars {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
        margin-top: 20px;
      }

      .pillars article {
        padding: 16px;
      }

      .pillars h2 {
        font-size: 1rem;
        margin-bottom: 8px;
      }

      .pillars p {
        margin: 0;
        color: var(--muted);
        line-height: 1.65;
      }

      .grid {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
      }

      .card {
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      .card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
      }

      .copy {
        padding: 20px;
      }

      .copy p {
        margin: 10px 0 18px;
        color: var(--muted);
        line-height: 1.7;
      }

      .footer-note {
        margin-top: 24px;
        padding: 18px 20px;
        border-left: 3px solid var(--accent);
        background: var(--surface-soft);
      }

      @media (max-width: 920px) {
        .hero,
        .grid,
        .pillars {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        main {
          width: min(100% - 24px, 720px);
          padding: 24px 0 48px;
        }

        .hero {
          padding: 20px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero" aria-label="Dionisio Developer">
        <div>
          <p class="eyebrow">Dionisio Developer</p>
          <h1>Dionisio Developer</h1>
          <p class="lede">
            Portfolio, writing, products, and technical reference by
            <a href="https://x.com/dionisiodev" target="_blank" rel="noopener noreferrer">@dionisiodev</a>
            across software engineering, applied AI, product thinking, and developer growth.
          </p>
          <div class="actions">
            <a class="action" href="/pt/">Entrar em português</a>
            <a class="action secondary" href="/en/">Enter in English</a>
          </div>
          <section class="pillars" aria-label="Main areas">
            {pillars.map((pillar) => (
              <article>
                <h2>{pillar.title}</h2>
                <p>{pillar.body}</p>
              </article>
            ))}
          </section>
        </div>

        <aside class="side-panel">
          <div>
            <p class="eyebrow">Across the web</p>
            <h2><a href="https://x.com/dionisiodev" target="_blank" rel="noopener noreferrer">@dionisiodev</a></h2>
          </div>
          <div class="socials">
            {socials.map((social) => (
              <a href={social.href} target="_blank" rel="noopener noreferrer">
                {social.label}
              </a>
            ))}
          </div>
          <div>
            <p class="eyebrow">Start here</p>
            <ul>
              <li>Open the portfolio for real projects, product thinking, and engineering decisions.</li>
              <li>Read the blog for technical perspective on software, AI, and career growth.</li>
              <li>Use the store and reference library for practical materials you can apply fast.</li>
            </ul>
          </div>
        </aside>
      </section>

      <section class="grid" aria-label="Language editions">
        {options.map((option) => (
          <article class="card">
            <img src={option.image} alt={option.title} loading="lazy" />
            <div class="copy">
              <p class="eyebrow">{option.title}</p>
              <h3>{option.description}</h3>
              <p>Same work, same identity, one home base in the language that fits best.</p>
              <a href={option.href} data-locale-link={option.locale}>{option.cta}</a>
            </div>
          </article>
        ))}
      </section>

      <div class="footer-note">
        One place to understand who Dionisio is, what he builds, what he writes, and what people
        can learn or buy from that work.
      </div>
    </main>

    <script is:inline>
      document.querySelectorAll('[data-locale-link]').forEach((link) => {
        link.addEventListener('click', () => {
          try {
            localStorage.setItem('preferredLocale', link.getAttribute('data-locale-link'));
          } catch {}
        });
      });
    </script>
  </body>
</html>
