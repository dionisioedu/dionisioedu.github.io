---
const options = [
  {
    locale: 'pt',
    title: 'Português',
    description: 'Portal para desenvolvedores com referências, artigos técnicos, projetos reais e trilhas de estudo.',
    href: '/pt/',
    cta: 'Entrar em Português',
  },
  {
    locale: 'en',
    title: 'English',
    description: 'A developer portal with references, technical articles, real projects, and practical learning paths.',
    href: '/en/',
    cta: 'Enter in English',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Dionisio Developer Portal</title>
    <meta
      name="description"
      content="Developer portal with technical references, articles, real projects, and curated learning paths in Portuguese and English."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #07111f;
        --bg-soft: #0c1a2d;
        --border: rgba(148, 193, 255, 0.18);
        --text: #f2f7ff;
        --muted: #b8c6df;
        --accent: #7dd3fc;
        --accent-2: #93c5fd;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Segoe UI", "Inter", system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(125, 211, 252, 0.14), transparent 28%),
          radial-gradient(circle at bottom right, rgba(147, 197, 253, 0.12), transparent 24%),
          linear-gradient(160deg, var(--bg) 0%, #091423 55%, #10213a 100%);
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 56px 0 72px;
      }

      .eyebrow {
        margin: 0 0 12px;
        font-size: 0.86rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
      }

      h1 {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.8rem);
        line-height: 0.95;
        max-width: 10ch;
      }

      .lede {
        margin: 18px 0 0;
        max-width: 62ch;
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--muted);
      }

      .grid {
        margin-top: 40px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
      }

      .card {
        padding: 24px;
        border: 1px solid var(--border);
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(12, 26, 45, 0.92), rgba(9, 19, 34, 0.86));
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.2);
      }

      .card h2 {
        margin: 0 0 10px;
        font-size: 1.5rem;
      }

      .card p {
        margin: 0 0 18px;
        line-height: 1.65;
        color: var(--muted);
      }

      .card a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        color: #03111f;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .highlights {
        margin-top: 30px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 14px;
      }

      .pill {
        padding: 14px 16px;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted);
      }

      @media (max-width: 780px) {
        main {
          width: min(100% - 24px, 680px);
          padding: 32px 0 48px;
        }

        .grid,
        .highlights {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Dionisio.dev</p>
      <h1>Developer portal, with a clear entry point.</h1>
      <p class="lede">
        Choose your language and enter a hub built to help developers study fundamentals,
        explore technical articles, inspect real projects, and move forward with more clarity.
      </p>

      <section class="grid" aria-label="Language options">
        {options.map((option) => (
          <article class="card">
            <h2>{option.title}</h2>
            <p>{option.description}</p>
            <a href={option.href} data-locale-link={option.locale}>{option.cta}</a>
          </article>
        ))}
      </section>

      <section class="highlights" aria-label="Portal highlights">
        <div class="pill">Reference pages for quick lookup and structured study</div>
        <div class="pill">Technical articles with context, trade-offs, and market perspective</div>
        <div class="pill">Real projects with architecture, decisions, and next-step guidance</div>
      </section>
    </main>

    <script is:inline>
      document.querySelectorAll('[data-locale-link]').forEach((link) => {
        link.addEventListener('click', () => {
          try {
            localStorage.setItem('preferredLocale', link.getAttribute('data-locale-link'));
          } catch {}
        });
      });
    </script>
  </body>
</html>
