---
const options = [
  {
    locale: 'pt',
    title: 'Português',
    description: 'Artigos, guias, labs e estudos de caso para quem quer acompanhar IA e engenharia de software com clareza.',
    href: '/pt/',
    cta: 'Entrar em Português',
    image: '/assets/images/chatgpt-1.webp',
  },
  {
    locale: 'en',
    title: 'English',
    description: 'Editorial technology coverage for software engineering, applied AI, practical guides, and case studies.',
    href: '/en/',
    cta: 'Enter in English',
    image: '/assets/images/desktop-3.webp',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>AI Engineering</title>
    <meta
      name="description"
      content="AI Engineering is a technology blog about software engineering, applied AI, practical guides, labs, and case studies in Portuguese and English."
    />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #050916;
        --panel: rgba(10, 18, 31, 0.88);
        --border: rgba(98, 206, 224, 0.16);
        --text: #f4fbff;
        --muted: #b4c3d3;
        --accent: #66d5e4;
        --accent-2: #8de6d2;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Segoe UI", "Inter", system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(102, 213, 228, 0.16), transparent 24%),
          radial-gradient(circle at bottom right, rgba(141, 230, 210, 0.14), transparent 22%),
          linear-gradient(160deg, var(--bg) 0%, #08111c 52%, #102032 100%);
      }

      main {
        width: min(1120px, calc(100% - 32px));
        margin: 0 auto;
        padding: 56px 0 72px;
      }

      .eyebrow {
        margin: 0 0 12px;
        font-size: 0.86rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent);
        font-weight: 700;
      }

      h1 {
        margin: 0;
        font-size: clamp(2.4rem, 5vw, 4.8rem);
        line-height: 0.95;
        max-width: 11ch;
      }

      .lede {
        margin: 18px 0 0;
        max-width: 62ch;
        font-size: 1.05rem;
        line-height: 1.7;
        color: var(--muted);
      }

      .hero-panel {
        margin-top: 28px;
        padding: 22px;
        border: 1px solid var(--border);
        border-radius: 8px;
        background:
          radial-gradient(circle at top left, rgba(102, 213, 228, 0.12), transparent 34%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.04), transparent),
          var(--panel);
        box-shadow: 0 22px 60px rgba(0, 0, 0, 0.24);
      }

      .hero-panel p {
        margin: 0;
        max-width: 68ch;
        color: var(--muted);
        line-height: 1.7;
      }

      .grid {
        margin-top: 40px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 20px;
      }

      .card {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: linear-gradient(180deg, rgba(12, 26, 45, 0.92), rgba(9, 19, 34, 0.86));
        box-shadow: 0 18px 50px rgba(0, 0, 0, 0.2);
      }

      .card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
      }

      .card-copy {
        padding: 20px 22px 22px;
      }

      .card h2 {
        margin: 0 0 10px;
        font-size: 1.5rem;
      }

      .card p {
        margin: 0 0 18px;
        line-height: 1.65;
        color: var(--muted);
      }

      .card a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        color: #03111f;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
      }

      .highlights {
        margin-top: 30px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
      }

      .pill {
        padding: 14px 16px;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
        color: var(--muted);
      }

      @media (max-width: 780px) {
        main {
          width: min(100% - 24px, 680px);
          padding: 32px 0 48px;
        }

        .grid,
        .highlights {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Dionisio.dev</p>
      <h1>AI Engineering</h1>
      <p class="lede">
        A technology blog for software engineering, applied AI, practical guides, labs,
        and case studies. Choose your language and enter the editorial front door.
      </p>
      <section class="hero-panel" aria-label="Editorial positioning">
        <p>
          This version shifts the project from a generic developer portal to an editorial
          product. Articles lead the experience, while guides, labs, and case studies stay
          close enough to turn reading into learning and shipping.
        </p>
      </section>

      <section class="grid" aria-label="Language options">
        {options.map((option) => (
          <article class="card">
            <img src={option.image} alt={option.title} loading="lazy" />
            <div class="card-copy">
              <h2>{option.title}</h2>
              <p>{option.description}</p>
              <a href={option.href} data-locale-link={option.locale}>{option.cta}</a>
            </div>
          </article>
        ))}
      </section>

      <section class="highlights" aria-label="Portal highlights">
        <div class="pill">Articles first, with a cleaner editorial hierarchy</div>
        <div class="pill">Guides for fundamentals, reference, and career direction</div>
        <div class="pill">Labs for hands-on learning directly in the browser</div>
        <div class="pill">Case studies that connect architecture, product, and delivery</div>
      </section>
    </main>

    <script is:inline>
      document.querySelectorAll('[data-locale-link]').forEach((link) => {
        link.addEventListener('click', () => {
          try {
            localStorage.setItem('preferredLocale', link.getAttribute('data-locale-link'));
          } catch {}
        });
      });
    </script>
  </body>
</html>
