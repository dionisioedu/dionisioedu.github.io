---
import { getCollection } from 'astro:content';
import { getLocalizedBlogPosts, formatBlogDate } from '../utils/blog';

const docs = await getCollection('docs');
const enPosts = getLocalizedBlogPosts(docs, 'en');
const latestPosts = enPosts.slice(0, 3);

const primaryLinks = [
  { label: 'About', href: '/en/about/' },
  { label: 'Blog', href: '/en/artigos-tecnicos/' },
  { label: 'Portfolio', href: '/en/projects/' },
  { label: 'Reference', href: '/en/reference/' },
];

const externalLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/' },
  { label: 'GitHub', href: 'https://github.com/dionisioedu' },
  { label: 'X', href: 'https://x.com/dionisiodev' },
  { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Eduardo Dionisio — C++ Engineer</title>
    <meta name="description" content="Senior C++ engineer. 20+ years building high-performance systems, trading infrastructure, and developer tools." />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Dionisio Developer Blog" href="/rss.xml" />
    <style>
      :root {
        color-scheme: dark;
        --bg: #0d1418;
        --surface: #101a20;
        --surface-hover: #16222a;
        --border: rgba(210, 233, 236, 0.08);
        --border-strong: rgba(210, 233, 236, 0.14);
        --text: #e8f0f3;
        --muted: #7a8f99;
        --accent: #38c6ca;
        --mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
        --sans: 'Inter', system-ui, -apple-system, sans-serif;
      }

      * { box-sizing: border-box; margin: 0; }

      body {
        font-family: var(--sans);
        color: var(--text);
        background: var(--bg);
        min-height: 100vh;
        line-height: 1.6;
      }

      .mono { font-family: var(--mono); font-size: 0.88em; }

      .container {
        max-width: 960px;
        margin: 0 auto;
        padding: 48px 24px 64px;
      }

      /* ── Hero ── */
      .hero {
        display: grid;
        gap: 12px;
        margin-bottom: 48px;
      }

      .hero-pre {
        color: var(--accent);
        font-family: var(--mono);
        font-size: 0.78rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        opacity: 0.8;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.1;
        color: #fff;
      }

      .hero .tagline {
        color: var(--muted);
        font-size: 1.05rem;
        max-width: 52ch;
        line-height: 1.7;
      }

      .hero .lang-switch {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 8px;
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        font-family: var(--mono);
        transition: color 140ms;
        width: fit-content;
      }
      .hero .lang-switch:hover { color: var(--accent); }

      /* ── Topbar ── */
      .topbar {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 24px;
        background: var(--bg);
        border-bottom: 1px solid var(--border);
        backdrop-filter: blur(8px);
      }
      .topbar .brand {
        font-family: var(--mono);
        font-size: 0.92rem;
        font-weight: 600;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: 0.02em;
      }
      .topbar .brand::before { content: '~/'; opacity: 0.5; }
      .topbar nav {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .topbar nav a {
        font-family: var(--mono);
        font-size: 0.74rem;
        color: var(--muted);
        text-decoration: none;
        transition: color 140ms;
      }
      .topbar nav a:hover { color: var(--accent); }
      .topbar .lang-link {
        margin-left: 8px;
        padding-left: 8px;
        border-left: 1px solid var(--border);
      }

      /* ── Nav strip ── */
      .nav-strip {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-bottom: 40px;
      }

      .nav-strip a {
        display: inline-flex;
        align-items: center;
        padding: 6px 14px;
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--text);
        font-size: 0.88rem;
        font-weight: 600;
        text-decoration: none;
        transition: border-color 140ms, background 140ms;
      }
      .nav-strip a:hover {
        border-color: var(--accent);
        background: var(--surface-hover);
      }
      .nav-strip a.external::after {
        content: ' ↗';
        font-size: 0.72rem;
        color: var(--muted);
        margin-left: 2px;
      }

      /* ── Sections ── */
      .section-title {
        font-family: var(--mono);
        font-size: 0.72rem;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 16px;
        opacity: 0.8;
      }

      .section {
        margin-bottom: 48px;
      }

      /* ── Blog posts ── */
      .post-list {
        display: grid;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: 6px;
        overflow: hidden;
      }

      .post-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 16px;
        align-items: baseline;
        padding: 16px 20px;
        background: var(--surface);
        text-decoration: none;
        transition: background 140ms;
      }
      .post-row:hover { background: var(--surface-hover); }

      .post-row h3 {
        font-size: 0.98rem;
        font-weight: 600;
        color: var(--text);
        line-height: 1.4;
      }
      .post-row .post-date {
        font-family: var(--mono);
        font-size: 0.75rem;
        color: var(--muted);
        white-space: nowrap;
      }
      .post-row .post-tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        margin-top: 4px;
      }
      .post-row .post-tags span {
        font-family: var(--mono);
        font-size: 0.66rem;
        color: var(--accent);
        opacity: 0.6;
        text-transform: uppercase;
        letter-spacing: 0.04em;
      }

      .view-all {
        display: inline-block;
        margin-top: 16px;
        font-family: var(--mono);
        font-size: 0.78rem;
        color: var(--accent);
        text-decoration: none;
        transition: color 140ms;
      }
      .view-all:hover { color: #fff; }
      .view-all::after { content: ' →'; }

      /* ── Newsletter ── */
      .newsletter-box {
        padding: 28px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: var(--surface);
      }
      .newsletter-box h2 {
        font-size: 1.1rem;
        margin: 0 0 6px;
      }
      .newsletter-box p {
        color: var(--muted);
        margin: 0 0 16px;
        font-size: 0.92rem;
        line-height: 1.6;
      }

      /* ── About snippet ── */
      .about-snippet {
        padding: 24px;
        border: 1px solid var(--border);
        border-radius: 6px;
        background: var(--surface);
        display: grid;
        gap: 12px;
      }
      .about-snippet p {
        color: var(--muted);
        font-size: 0.94rem;
        line-height: 1.7;
        max-width: 60ch;
      }
      .about-snippet .highlight {
        color: var(--text);
        font-weight: 600;
      }

      /* ── Footer ── */
      .footer {
        margin-top: 64px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-wrap: wrap;
        gap: 8px 24px;
        font-size: 0.78rem;
        color: var(--muted);
        font-family: var(--mono);
      }
      .footer a {
        color: var(--muted);
        text-decoration: none;
        transition: color 140ms;
      }
      .footer a:hover { color: var(--accent); }

      @media (max-width: 640px) {
        .container { padding: 32px 16px 48px; }
        .post-row { grid-template-columns: 1fr; gap: 4px; padding: 14px 16px; }
      }
    </style>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Eduardo Dionisio",
        "givenName": "Eduardo",
        "familyName": "Dionisio Fernandes",
        "alternateName": "dionisiodev",
        "jobTitle": "Senior C++ Software Engineer",
        "url": "https://dionisio.dev",
        "sameAs": [
          "https://www.linkedin.com/in/dionisiodev/",
          "https://github.com/dionisioedu",
          "https://x.com/dionisiodev",
          "https://www.youtube.com/@dionisiodev"
        ],
        "knowsAbout": ["C++", "Low-Latency Systems", "High-Frequency Trading", "Performance Engineering", "Software Architecture", "AI Engineering", "Real-Time Systems"],
        "description": "C++ Software Developer & AI Engineer with 20+ years building high-performance systems and developer tools."
      }
    </script>
  </head>
  <body>
    <header class="topbar">
      <a class="brand" href="/">dionisio</a>
      <nav>
        <a class="lang-link" href="/pt/">PT</a>
        <a href="/en/about/">About</a>
        <a href="/en/artigos-tecnicos/">Blog</a>
        <a href="/en/open-source/">OSS</a>
        <a href="/en/shop/">Shop</a>
      </nav>
    </header>
    <div class="container">
      <!-- Hero -->
      <section class="hero">
        <p class="hero-pre">~/eduardo.dionisio $ whoami</p>
        <h1>Eduardo Dionisio</h1>
        <p class="tagline">
          Senior C++ engineer. AI engineer. <span class="mono">20+</span> years building high-performance systems,
          trading infrastructure, and developer tools.
          I write about <span class="mono">C++</span>, low-latency, cache, and systems engineering.
        </p>
        <a class="lang-switch" href="/pt/">🇧🇷 Também disponível em português</a>
      </section>

      <!-- Nav -->
      <nav class="nav-strip">
        {primaryLinks.map(link => <a href={link.href}>{link.label}</a>)}
        {externalLinks.map(link => <a href={link.href} class="external" target="_blank" rel="noopener noreferrer">{link.label}</a>)}
      </nav>

      <!-- Latest posts -->
      <section class="section">
        <p class="section-title">// Latest writing</p>
        <div class="post-list">
          {latestPosts.map(post => (
            <a href={post.href} class="post-row">
              <div>
                <h3>{post.title}</h3>
                {post.tags.length > 0 && (
                  <div class="post-tags">
                    {post.tags.slice(0, 3).map(tag => <span>{tag.label}</span>)}
                  </div>
                )}
              </div>
              <span class="post-date">{post.publishedAt ? formatBlogDate(post.publishedAt, 'en') : ''}</span>
            </a>
          ))}
        </div>
        <a class="view-all" href="/en/artigos-tecnicos/">All articles →</a>
      </section>

      <!-- Newsletter -->
      <section class="section">
        <p class="section-title">// Newsletter</p>
        <div class="newsletter-box">
          <h2>Get new articles in your inbox</h2>
          <p>C++, low-latency, performance engineering, and the stuff that makes software fast. No spam, unsubscribe anytime.</p>
          <script async data-uid="6fa15fabec" src="https://dionisio-developer.kit.com/6fa15fabec/index.js"></script>
        </div>
      </section>

      <!-- About snippet -->
      <section class="section">
        <p class="section-title">// About</p>
        <div class="about-snippet">
          <p>
            <span class="highlight">Eduardo Dionisio Fernandes.</span>
            20+ years in C++ — from real-time embedded systems to distributed trading platforms.
            Based in Brazil, working remotely for global teams.
          </p>
          <p>
            I built <span class="highlight">Code Royale</span> — a multiplayer coding battle platform —
            and maintain open-source projects across Go, TypeScript, and Python.
            I share daily on <span class="highlight">X</span> where 8K+ developers follow my work.
            I believe in <span class="mono">conscious C++</span>: knowing what happens between your
            code and the silicon.
          </p>
          <a class="view-all" href="/en/about/">More about me →</a>
        </div>
      </section>

      <!-- Footer -->
      <footer class="footer">
        <span>© {new Date().getFullYear()} Eduardo Dionisio</span>
        <a href="/rss.xml">RSS</a>
        <a href="/en/">Home (EN)</a>
        <a href="/pt/">Português</a>
      </footer>
    </div>
  </body>
</html>
