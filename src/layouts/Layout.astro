---
import type { MarkdownLayoutProps } from 'astro';
import StarlightLayout from '@astrojs/starlight/layouts/BaseLayout.astro';

type Props = MarkdownLayoutProps<{
  title: string;
  description?: string;
}>;

const { frontmatter, ...rest } = Astro.props;
---

<StarlightLayout {...rest} frontmatter={frontmatter}>
  <slot />
  
  <script>
    // Translate sidebar labels for English locale
    if (window.location.pathname.startsWith('/en/')) {
      const translations = {
        'Loja': 'Shop',
        'Artigos Técnicos': 'Technical Articles',
        'Referência': 'Reference',
        'Notas de Arquitetura': 'Architecture Notes',
        'Padrões de Engenharia': 'Engineering Standards',
        'Estruturas de Dados e Algoritmos': 'Data Structures & Algorithms',
        'Tutoriais': 'Tutorials',
        'Hello World no C++': 'Hello World in C++',
        'Projetos': 'Projects',
      };

      // Function to recursively translate text nodes
      function translateElement(element) {
        const walker = document.createTreeWalker(
          element,
          NodeFilter.SHOW_TEXT,
          null,
          false
        );
        
        let node;
        while (node = walker.nextNode()) {
          const text = node.textContent?.trim();
          if (text && translations[text]) {
            node.textContent = translations[text];
          }
        }
      }

      // Run on every navigation
      const observer = new MutationObserver(() => {
        const sidebar = document.querySelector('[aria-label="Sidebar"]') || 
                       document.querySelector('nav[aria-label*="ide"]') ||
                       document.querySelector('[role="navigation"]');
        if (sidebar) {
          translateElement(sidebar);
        }
      });

      observer.observe(document.body, { childList: true, subtree: true });

      // Initial translation
      const sidebar = document.querySelector('[aria-label="Sidebar"]') || 
                     document.querySelector('nav[aria-label*="ide"]') ||
                     document.querySelector('[role="navigation"]');
      if (sidebar) {
        translateElement(sidebar);
      }
    }
  </script>
</StarlightLayout>
