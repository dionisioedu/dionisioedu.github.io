---
const height = Astro.props.height ?? 520;
const accent = Astro.props.accent ?? "currentColor";
const label = Astro.props.label ?? "3D Knowledge Navigator";
---

<section
  class="knowledge-nav-3d"
  data-graph3d="knowledge"
  aria-label={label}
  style={`--h:${height}px; --accent:${accent};`}
>
  <div class="nav3d-frame" data-graph3d-frame>
    <canvas class="nav3d-canvas" data-graph3d-canvas></canvas>

    <div class="nav3d-gradient" aria-hidden="true"></div>

    <aside class="nav3d-panel" data-graph3d-panel>
      <div class="panel-kicker" data-graph3d-kicker>Knowledge Navigator</div>
      <h3 class="panel-title" data-graph3d-title>Explore by area</h3>

      <div class="panel-actions">
        <a class="primary-btn" data-graph3d-open href="#">Open area</a>
        <a class="secondary-btn" data-graph3d-index href="#">Docs</a>
      </div>

      <div class="panel-list" data-graph3d-list></div>
    </aside>
  </div>
</section>

<script>
  async function loadKnowledgeGraphModule() {
    if (window.__knowledgeNavigatorModule) {
      return window.__knowledgeNavigatorModule;
    }
    window.__knowledgeNavigatorModule = await import('./KnowledgeGraph3D.client.js');
    return window.__knowledgeNavigatorModule;
  }

  async function mountFor(rootEl) {
    if (!rootEl) return;

    if (rootEl.__graphCleanup) {
      rootEl.__graphCleanup();
      rootEl.__graphCleanup = null;
    }

    const mod = await loadKnowledgeGraphModule();
    rootEl.__graphCleanup = mod.mountKnowledgeGraph3D(rootEl);
  }

  function initWhenVisible(rootEl) {
    if (!rootEl) return;

    const observer = new IntersectionObserver(async (entries) => {
      if (entries[0]?.isIntersecting) {
        observer.disconnect();
        await mountFor(rootEl);
      }
    }, { rootMargin: '120px' });

    observer.observe(rootEl);
  }

  document.querySelectorAll('[data-graph3d="knowledge"]').forEach((el) => {
    initWhenVisible(el);
  });

  document.addEventListener('astro:before-swap', () => {
    document.querySelectorAll('[data-graph3d="knowledge"]').forEach((el) => {
      if (el.__graphCleanup) {
        el.__graphCleanup();
        el.__graphCleanup = null;
      }
    });
  });

  document.addEventListener('astro:after-swap', () => {
    document.querySelectorAll('[data-graph3d="knowledge"]').forEach((el) => {
      initWhenVisible(el);
    });
  });
</script>

<style>
  .knowledge-nav-3d {
    --h: 520px;
    --accent: currentColor;
    width: 100%;
    height: var(--h);
    margin: 0;
  }

  .nav3d-frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 16px;
    border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--accent) 8%, #0b1020) 0%,
      #0b1020 38%,
      #111a2e 100%
    );
  }

  .nav3d-canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .nav3d-gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 72% 30%, color-mix(in srgb, var(--accent) 35%, transparent) 0%, transparent 50%),
      radial-gradient(circle at 32% 88%, rgba(255, 255, 255, 0.06) 0%, transparent 48%);
    pointer-events: none;
  }

  .nav3d-panel {
    position: absolute;
    top: 10px;
    left: 10px;
    width: min(180px, calc(100% - 20px));
    padding: 8px;
    border-radius: 10px;
    backdrop-filter: blur(10px);
    background: color-mix(in srgb, #0a1222 74%, transparent);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    gap: 6px;
  }

  .panel-kicker {
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--accent) 70%, white);
    font-weight: 700;
  }

  .panel-title {
    margin: 0;
    line-height: 1.15;
    font-size: 0.86rem;
    color: #fff;
  }

  .panel-actions {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }

  .primary-btn,
  .secondary-btn,
  .area-btn {
    text-decoration: none;
    border-radius: 10px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    transition: background 120ms ease, border-color 120ms ease, transform 120ms ease;
  }

  .primary-btn,
  .secondary-btn {
    padding: 5px 6px;
    text-align: center;
    font-size: 0.64rem;
    font-weight: 650;
  }

  .primary-btn {
    color: #0b1120;
    background: color-mix(in srgb, var(--accent) 75%, white);
    border-color: transparent;
  }

  .secondary-btn {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }

  .primary-btn:hover,
  .secondary-btn:hover,
  .area-btn:hover {
    transform: translateY(-1px);
    border-color: color-mix(in srgb, var(--accent) 45%, rgba(255, 255, 255, 0.4));
  }

  .panel-list {
    display: grid;
    gap: 4px;
    align-content: start;
    overflow: auto;
    max-height: 116px;
  }

  .area-btn {
    display: block;
    padding: 4px 6px;
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.9);
    border-radius: 8px;
  }

  .area-btn strong {
    display: block;
    font-size: 0.66rem;
    line-height: 1.2;
  }

  .area-btn span {
    display: none;
  }

  .area-btn.is-active {
    border-color: color-mix(in srgb, var(--accent) 80%, rgba(255, 255, 255, 0.35));
    background: color-mix(in srgb, var(--accent) 24%, rgba(255, 255, 255, 0.05));
  }

  @media (max-width: 920px) {
    .knowledge-nav-3d {
      --h: 640px;
    }

    .nav3d-panel {
      width: min(168px, calc(100% - 20px));
    }
  }

  @media (max-width: 640px) {
    .knowledge-nav-3d {
      --h: 720px;
    }

    .nav3d-panel {
      width: min(154px, calc(100% - 20px));
      padding: 7px;
    }

    .panel-list {
      max-height: 95px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav3d-panel {
      backdrop-filter: none;
    }

    .primary-btn,
    .secondary-btn,
    .area-btn {
      transition: none;
    }
  }
</style>
