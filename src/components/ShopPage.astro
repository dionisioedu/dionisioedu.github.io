    ],
    useTogether: 'Use together',
    useTogetherTitle: 'Best flow',
    useTogetherItems: [
      { href: '/en/blog/', label: 'Blog', suffix: ' for context and perspective' },
      { href: '/en/reference/', label: 'Reference', suffix: ' for fundamentals and practice' },
      { href: '/en/projects/', label: 'Portfolio', suffix: ' for delivery and product cases' },
    ],
    products: 'Products',
    productsTitle: 'Dionisio Developer materials',
    available: 'Available',
    comingSoon: 'Coming soon',
    futureRelease: 'Future release',
    futureOpening: 'Future opening',
    buy: 'Buy now',
    recommendations: 'Recommendations',
    recommendationsTitle: 'Useful setup and routine picks for developers',
    affiliate: 'Affiliate',
    viewOffer: 'View offer',
    followLaunches: 'Follow future launches',
    ctaTitle: 'New materials will keep coming from the work, the writing, and the questions people bring',
    ctaBodyPrefix: 'To keep up with updates, follow ',
    ctaBodyMiddle1: ' on ',
    ctaBodyMiddle2: ', ',
    ctaBodyMiddle3: ', ',
    ctaBodyMiddle4: ', and ',
    readBlog: 'Read the Blog',
    viewPortfolio: 'View Portfolio',
    productsList: [
      {
        image: '/assets/images/books-1.webp',
        alt: 'Beginner Developer Guide cover art',
        badge: 'Available',
        title: 'Beginner Developer Guide',
        body: 'A direct resource for landing the first role with stronger projects, positioning, and study structure.',
        meta: ['eBook', 'Career', 'First job'],
        oldPrice: '$9.99',
        currentPrice: '$5.99',
        href: 'https://pay.hotmart.com/F98094178H?off=fqzq49bv',
        action: 'Buy now',
      },
      {
        image: '/assets/images/books-2.webp',
        alt: 'Advanced C++ guide cover art',
        badge: 'Available',
        title: 'Advanced C++: Quant Developer',
        body: 'A deeper read for professional C++, performance thinking, and the quant market with real examples.',
        meta: ['eBook', 'C++', 'Quant'],
        oldPrice: '$14.99',
        currentPrice: '$7.99',
        href: 'https://pay.hotmart.com/M99932004R',
        action: 'Buy now',
      },
      {
        image: '/assets/images/desktop-3.webp',
        alt: 'Software architecture workspace',
        badge: 'Coming soon',
        title: 'Masterclass: Software Architecture',
        body: 'A next step for people who want to firm up patterns, trade-offs, and architecture thinking with practical application.',
        meta: ['Course', 'Architecture', 'Execution'],
        currentPrice: 'Coming soon',
