    useTogether: 'Use junto',
    useTogetherTitle: 'Fluxo ideal',
    useTogetherItems: [
      { href: '/pt/blog/', label: 'Blog', suffix: ' para contexto e visão' },
      { href: '/pt/reference/', label: 'Referência', suffix: ' para base e prática' },
      { href: '/pt/projects/', label: 'Portfólio', suffix: ' para observar entrega e produto' },
