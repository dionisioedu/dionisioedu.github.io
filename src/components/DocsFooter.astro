---
import RelatedPosts from './RelatedPosts.astro';

const isPt = Astro.url.pathname.startsWith('/pt');
const year = new Date().getFullYear();
type FooterLink = { label: string; href: string; external?: boolean };

const isBlogPost = Astro.url.pathname.includes('/artigos-tecnicos/') && !Astro.url.pathname.endsWith('/artigos-tecnicos/');

const followCta = isPt
  ? { text: 'Gostou do artigo? Me acompanhe no', links: [
      { label: 'X', href: 'https://x.com/dionisiodev' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/' },
      { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev' },
      { label: 'RSS', href: '/rss.xml' },
    ]}
  : { text: 'Enjoyed this article? Follow me on', links: [
      { label: 'X', href: 'https://x.com/dionisiodev' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/' },
      { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev' },
      { label: 'RSS', href: '/rss.xml' },
    ]};

const copy = isPt
  ? {
      kicker: 'Dionisio Developer',
      title: 'Portfólio, blog, materiais e referência técnica em torno de @dionisiodev.',
      body:
        'O ponto central para acompanhar projetos, textos, produtos e a forma como Dionisio pensa software, IA aplicada, carreira e construção de produto.',
      groups: [
        {
          title: 'Acompanhe',
          links: [
            { label: 'X', href: 'https://x.com/dionisiodev', external: true },
            { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev', external: true },
            { label: 'Medium', href: 'https://medium.com/@dionisiodev', external: true },
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/', external: true },
          ],
        },
        {
          title: 'Explorar',
          links: [
            { label: 'Portfólio', href: '/pt/projects/' },
            { label: 'Blog', href: '/pt/blog/' },
            { label: 'Loja', href: '/pt/shop/' },
            { label: 'Referência', href: '/pt/reference/' },
          ],
        },
        {
          title: 'Comece por aqui',
          links: [
            { label: 'Currículo que se destaca', href: '/pt/reference/curriculo-que-se-destaca/' },
            { label: 'Por onde começar', href: '/pt/reference/getting-started/' },
            { label: 'Code Lab', href: '/pt/reference/code-lab/' },
            { label: 'eBooks', href: '/pt/books/' },
          ],
        },
      ],
      bottomLeft: `© ${year} Dionisio Developer`,
      bottomRight: '@dionisiodev no X, YouTube, Medium e LinkedIn.',
    }
  : {
      kicker: 'Dionisio Developer',
      title: 'Portfolio, writing, products, and technical reference around @dionisiodev.',
      body:
        'The home base for following projects, articles, products, and the way Dionisio approaches software, applied AI, career growth, and product work.',
      groups: [
        {
          title: 'Follow',
          links: [
            { label: 'X', href: 'https://x.com/dionisiodev', external: true },
            { label: 'YouTube', href: 'https://www.youtube.com/@dionisiodev', external: true },
            { label: 'Medium', href: 'https://medium.com/@dionisiodev', external: true },
            { label: 'LinkedIn', href: 'https://www.linkedin.com/in/dionisiodev/', external: true },
          ],
        },
        {
          title: 'Explore',
          links: [
            { label: 'Portfolio', href: '/en/projects/' },
            { label: 'Blog', href: '/en/blog/' },
            { label: 'Shop', href: '/en/shop/' },
            { label: 'Reference', href: '/en/reference/' },
          ],
        },
        {
          title: 'Start here',
          links: [
            { label: 'Resume that stands out', href: '/en/reference/curriculo-que-se-destaca/' },
            { label: 'Where to start', href: '/en/reference/getting-started/' },
            { label: 'Code Lab', href: '/en/reference/code-lab/' },
            { label: 'eBooks', href: '/en/books/' },
          ],
        },
      ],
      bottomLeft: `© ${year} Dionisio Developer`,
      bottomRight: '@dionisiodev on X, YouTube, Medium, and LinkedIn.',
    };
---

<footer class="ae-site-footer">
  {isBlogPost && <RelatedPosts />}
  {
    isBlogPost && (
      <div class="ae-follow-cta">
        <p>{followCta.text} {followCta.links.map((l, i) => (
          <>{i > 0 && ' · '}<a href={l.href} target="_blank" rel="noopener noreferrer">{l.label}</a></>
        ))}</p>
      </div>
    )
  }
  {
    isBlogPost && (
      <div class="ae-newsletter-cta">
        <script async data-uid="6fa15fabec" src="https://dionisio-developer.kit.com/6fa15fabec/index.js"></script>
      </div>
    )
  }
  <section class="ae-footer-shell" aria-label={copy.kicker}>
    <div class="ae-footer-intro">
      <p class="ae-kicker">{copy.kicker}</p>
      <h2>{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="ae-footer-grid">
      {copy.groups.map((group) => (
        <section class="ae-footer-column">
          <h3>{group.title}</h3>
          <ul>
            {group.links.map((link: FooterLink) => (
              <li>
                <a
                  href={link.href}
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>

  <div class="ae-footer-bottom">
    <p>{copy.bottomLeft}</p>
    <p>{copy.bottomRight}</p>
  </div>
</footer>
