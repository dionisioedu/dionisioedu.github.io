---
const isPt = Astro.url.pathname.startsWith('/pt');
const year = new Date().getFullYear();

const copy = isPt
  ? {
      kicker: 'AI Engineering',
      title: 'Leitura técnica para quem constrói software no mundo real.',
      body:
        'Arquitetura, IA aplicada, confiabilidade, fundamentos e ferramentas em um fluxo editorial pensado para consulta, estudo e tomada de decisão.',
      groups: [
        {
          title: 'Explorar',
          links: [
            { label: 'Hub editorial', href: '/pt/blog/' },
            { label: 'Guias', href: '/pt/reference/' },
            { label: 'Labs', href: '/pt/reference/code-lab/' },
          ],
        },
        {
          title: 'Ler por tema',
          links: [
            { label: 'IA aplicada', href: '/pt/artigos-tecnicos/ia-vai-acabar-com-os-devs/' },
            { label: 'SRE e confiabilidade', href: '/pt/artigos-tecnicos/sre/' },
            { label: 'Fundamentos', href: '/pt/artigos-tecnicos/bigo/' },
          ],
        },
        {
          title: 'Aprofundar',
          links: [
            { label: 'Case studies', href: '/pt/projects/' },
            { label: 'Carreira', href: '/pt/reference/curriculo-que-se-destaca/' },
            { label: 'Edição em inglês', href: '/en/' },
          ],
        },
      ],
      bottomLeft: `© ${year} AI Engineering`,
      bottomRight: 'Leitura editorial para engenharia de software, desenvolvimento e IA.',
    }
  : {
      kicker: 'AI Engineering',
      title: 'Technical reading for people building software in the real world.',
      body:
        'Architecture, applied AI, reliability, foundations, and tooling in an editorial flow designed for study, reference, and better technical judgment.',
      groups: [
        {
          title: 'Explore',
          links: [
            { label: 'Editorial hub', href: '/en/blog/' },
            { label: 'Guides', href: '/en/reference/' },
            { label: 'Labs', href: '/en/reference/code-lab/' },
          ],
        },
        {
          title: 'Read by topic',
          links: [
            { label: 'Applied AI', href: '/en/artigos-tecnicos/ia-vai-acabar-com-os-devs/' },
            { label: 'SRE and reliability', href: '/en/artigos-tecnicos/sre/' },
            { label: 'Foundations', href: '/en/artigos-tecnicos/bigo/' },
          ],
        },
        {
          title: 'Go deeper',
          links: [
            { label: 'Case studies', href: '/en/projects/' },
            { label: 'Career', href: '/en/reference/curriculo-que-se-destaca/' },
            { label: 'Portuguese edition', href: '/pt/' },
          ],
        },
      ],
      bottomLeft: `© ${year} AI Engineering`,
      bottomRight: 'Editorial reading for software engineering, development, and AI.',
    };
---

<footer class="ae-site-footer">
  <section class="ae-footer-shell" aria-label={copy.kicker}>
    <div class="ae-footer-intro">
      <p class="ae-kicker">{copy.kicker}</p>
      <h2>{copy.title}</h2>
      <p>{copy.body}</p>
    </div>

    <div class="ae-footer-grid">
      {copy.groups.map((group) => (
        <section class="ae-footer-column">
          <h3>{group.title}</h3>
          <ul>
            {group.links.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>

  <div class="ae-footer-bottom">
    <p>{copy.bottomLeft}</p>
    <p>{copy.bottomRight}</p>
  </div>
</footer>
